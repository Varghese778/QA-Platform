# =============================================================================
# QA PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update values for your environment
#
# IMPORTANT FOR DOCKER:
# - Use service names (postgres, redis, auth-service, etc.) instead of localhost
# - Database URLs must use: postgresql+asyncpg://user:pass@postgres:5432/db_name
# - Redis URLs must use: redis://redis:6379/db_number
# =============================================================================

# =============================================================================
# INFRASTRUCTURE SERVICES
# =============================================================================

# PostgreSQL Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=qa_platform

# Redis Cache & Queue
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# AUTH SERVICE (Port: 8000)
# =============================================================================

AUTH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/qa_platform
AUTH_REDIS_URL=redis://redis:6379/0
AUTH_DEBUG=false

# JWT Configuration
AUTH_JWT_ISSUER=https://auth.qaplatform.internal
AUTH_JWT_AUDIENCE=qaplatform-api
AUTH_JWT_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_JWT_REFRESH_TOKEN_TTL_DAYS=7
AUTH_JWT_ALGORITHM=RS256
AUTH_JWT_CLOCK_SKEW_SECONDS=5

# Security
AUTH_API_KEY_LENGTH=64
AUTH_INVITATION_TOKEN_TTL_DAYS=7
AUTH_BRUTE_FORCE_MAX_ATTEMPTS=10
AUTH_BRUTE_FORCE_WINDOW_MINUTES=10
AUTH_BRUTE_FORCE_LOCKOUT_MINUTES=30

# =============================================================================
# API GATEWAY (Port: 8080)
# =============================================================================

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_DEBUG=false

# Redis for rate limiting
GATEWAY_REDIS_URL=redis://redis:6379/7

# JWT/Auth
GATEWAY_JWKS_URL=http://auth-service:8000/auth/v1/.well-known/jwks.json
GATEWAY_JWT_ISSUER=https://auth.qaplatform.internal
GATEWAY_JWT_AUDIENCE=qaplatform-api
GATEWAY_JWT_CLOCK_SKEW_SECONDS=5
GATEWAY_JWKS_CACHE_TTL_SECONDS=900

# Downstream Services (use Docker service names)
GATEWAY_AUTH_SERVICE_URL=http://auth-service:8000
GATEWAY_ORCHESTRATOR_SERVICE_URL=http://orchestrator-service:8000
GATEWAY_ARTIFACT_SERVICE_URL=http://artifact-storage:8000
GATEWAY_ASYNC_SERVICE_URL=http://async-processing:8000

# Timeouts
GATEWAY_DOWNSTREAM_TIMEOUT_SECONDS=30.0
GATEWAY_WEBSOCKET_PING_INTERVAL_SECONDS=60

# Request Limits
GATEWAY_MAX_REQUEST_BODY_BYTES=1048576
GATEWAY_MAX_UPLOAD_FILE_BYTES=10485760
GATEWAY_MAX_UPLOAD_FILES_COUNT=5

# CORS (add all frontend origins)
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80,http://localhost

# Rate Limiting
GATEWAY_RATE_LIMIT_USER_PER_MINUTE=100
GATEWAY_RATE_LIMIT_PROJECT_PER_MINUTE=500
GATEWAY_RATE_LIMIT_FAIL_OPEN=true

# =============================================================================
# ORCHESTRATOR SERVICE (Port: 8001)
# =============================================================================

ORCHESTRATOR_HOST=0.0.0.0
ORCHESTRATOR_PORT=8001
ORCHESTRATOR_DEBUG=false

ORCHESTRATOR_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/qa_platform
ORCHESTRATOR_REDIS_URL=redis://redis:6379/1

# Downstream Services (use Docker service names)
ORCHESTRATOR_MULTI_AGENT_ENGINE_URL=http://multi-agent-engine:8000
ORCHESTRATOR_MEMORY_LAYER_URL=http://memory-layer:8000
ORCHESTRATOR_ARTIFACT_STORAGE_URL=http://artifact-storage:8000
ORCHESTRATOR_EXECUTION_ENGINE_URL=http://execution-engine:8000
ORCHESTRATOR_ASYNC_PROCESSING_URL=http://async-processing:8000

# Timeouts
ORCHESTRATOR_DEFAULT_JOB_TIMEOUT_SECONDS=1800
ORCHESTRATOR_DEFAULT_TASK_TIMEOUT_SECONDS=300
ORCHESTRATOR_HTTP_CLIENT_TIMEOUT_SECONDS=30.0

# Retry Configuration
ORCHESTRATOR_MAX_TASK_RETRIES=3
ORCHESTRATOR_RETRY_BACKOFF_BASE_SECONDS=5

# Scheduler
ORCHESTRATOR_SCHEDULER_POLL_INTERVAL_SECONDS=10
ORCHESTRATOR_WATCHDOG_CHECK_INTERVAL_SECONDS=30

# =============================================================================
# MULTI-AGENT ENGINE (Port: 8010)
# =============================================================================

AGENT_HOST=0.0.0.0
AGENT_PORT=8010
AGENT_DEBUG=false

AGENT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/qa_platform
AGENT_REDIS_URL=redis://redis:6379/2

# Downstream Services
AGENT_MEMORY_LAYER_URL=http://memory-layer:8000

# Agent Pool Configuration
AGENT_POOL_SIZE=5
AGENT_MAX_CONCURRENT_TASKS_PER_AGENT=3
AGENT_TASK_QUEUE_MAX_SIZE=100

# LLM Configuration (mock for MVP)
AGENT_LLM_PROVIDER=mock
AGENT_LLM_MODEL=gpt-4
AGENT_LLM_TIMEOUT_SECONDS=60

# =============================================================================
# MEMORY LAYER (Port: 8011)
# =============================================================================

MEMORY_HOST=0.0.0.0
MEMORY_PORT=8011
MEMORY_DEBUG=false

MEMORY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/qa_platform
MEMORY_REDIS_URL=redis://redis:6379/3

# Vector Embeddings (mock for MVP)
MEMORY_EMBEDDING_DIMENSION=1536
MEMORY_EMBEDDING_MODEL=text-embedding-ada-002

# Retention
MEMORY_RETENTION_DAYS=365
MEMORY_CACHE_TTL_SECONDS=86400

# =============================================================================
# ARTIFACT STORAGE (Port: 8012)
# =============================================================================

ARTIFACT_HOST=0.0.0.0
ARTIFACT_PORT=8012
ARTIFACT_DEBUG=false

ARTIFACT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/qa_platform
ARTIFACT_REDIS_URL=redis://redis:6379/4

# Storage Backend
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_LOCAL_STORAGE_PATH=/app/storage
ARTIFACT_MAX_UPLOAD_SIZE_BYTES=536870912
ARTIFACT_PRESIGNED_URL_TTL_SECONDS=3600

# Virus Scanning
ARTIFACT_ENABLE_VIRUS_SCAN=true
ARTIFACT_SCAN_QUEUE_NAME=artifact:scan

# =============================================================================
# EXECUTION ENGINE (Port: 8013)
# =============================================================================

EXECUTION_HOST=0.0.0.0
EXECUTION_PORT=8013
EXECUTION_DEBUG=false

EXECUTION_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/qa_platform
EXECUTION_REDIS_URL=redis://redis:6379/5

# Downstream Services
EXECUTION_ARTIFACT_STORAGE_URL=http://artifact-storage:8000
EXECUTION_MEMORY_LAYER_URL=http://memory-layer:8000

# Test Execution Configuration
EXECUTION_DEFAULT_TIMEOUT_SECONDS=300
EXECUTION_RUNNER_POOL_SIZE=5
EXECUTION_MAX_CONCURRENT_EXECUTIONS=10

# Flaky Detection
EXECUTION_FLAKY_RETRY_COUNT=1
EXECUTION_FLAKY_THRESHOLD_PERCENT=20

# =============================================================================
# ASYNC PROCESSING (Port: 8014)
# =============================================================================

ASYNC_HOST=0.0.0.0
ASYNC_PORT=8014
ASYNC_DEBUG=false

ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/qa_platform
ASYNC_REDIS_URL=redis://redis:6379/6

# Redis Streams
ASYNC_STREAM_NAME=qa:events
ASYNC_CONSUMER_GROUP_NAME=qa-consumers
ASYNC_CONSUMER_NAME=worker-1

# WebSocket Configuration
ASYNC_WEBSOCKET_HEARTBEAT_INTERVAL_SECONDS=30
ASYNC_WEBSOCKET_MAX_CONNECTIONS=1000

# Dead Letter Queue
ASYNC_DLQ_MAX_RETRIES=3
ASYNC_DLQ_RETENTION_DAYS=7

# =============================================================================
# OBSERVABILITY (Port: 8015)
# =============================================================================

OBSERVABILITY_HOST=0.0.0.0
OBSERVABILITY_PORT=8015
OBSERVABILITY_DEBUG=false

OBSERVABILITY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/qa_platform

# Retention Policies
OBSERVABILITY_LOG_RETENTION_DAYS=30
OBSERVABILITY_METRIC_RETENTION_DAYS=90
OBSERVABILITY_TRACE_RETENTION_DAYS=14

# Alert Engine
OBSERVABILITY_ALERT_CHECK_INTERVAL_SECONDS=60
OBSERVABILITY_ALERT_EVALUATION_WINDOW_SECONDS=300

# =============================================================================
# FRONTEND DASHBOARD
# =============================================================================

# API Endpoints (for production, use actual domain)
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_WS_BASE_URL=ws://localhost:8080/ws/v1
VITE_AUTH_SERVICE_URL=http://localhost:8000

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# For production deployments, override these values:
#
# - Replace localhost with your actual domain
# - Use strong passwords for PostgreSQL
# - Configure proper JWT key paths
# - Enable TLS/SSL for all services
# - Set DEBUG=false for all services
# - Configure proper log aggregation
# - Set up external secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
# =============================================================================
